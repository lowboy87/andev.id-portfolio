# ============================================
# PORTFOLIO - ENVIRONMENT VARIABLES
# ============================================
# Salin file ini menjadi .env.local dan isi nilai yang sesuai

# ============================================
# WHATSAPP (WAJIB)
# ============================================
# Ganti dengan nomor WhatsApp Anda (format internasional tanpa +)
NEXT_PUBLIC_WHATSAPP_NUMBER=6285274123456

# ============================================
# EMAILJS (OPSIONAL - untuk kirim email)
# ============================================
# Daftar di https://emailjs.com dan buat service + template
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx

# ============================================
# DATABASE (OPSIONAL - untuk CMS Admin)
# ============================================
# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres

# ============================================
# NEXTAUTH (OPSIONAL - untuk Admin Login)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars

# ============================================
# ADMIN CREDENTIALS
# ============================================
ADMIN_EMAIL=admin@andredev.id
ADMIN_PASSWORD=your-secure-password

# ============================================
# ANALYTICS (OPSIONAL)
# ============================================
# Google Analytics 4
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
